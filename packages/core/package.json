{
  "name": "@agentic-app/core",
  "version": "1.0.0",
  "description": "Shared AWS utilities for Knowledge Base RAG Agent",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@agentic-app/types": "*"
  },
  "devDependencies": {
    "@agentic-app/config-ts": "*",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}