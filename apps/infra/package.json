{
  "name": "@agentic-app/infra",
  "version": "1.0.0",
  "description": "CDK Infrastructure for Knowledge Base RAG Agent",
  "private": true,
  "main": "bin/infrastructure.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:stacks": "jest test/stacks",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "type-check": "tsc --noEmit",
    "cdk": "cdk --app \"npx ts-node bin/infrastructure.ts\"",
    "deploy": "./deploy.sh",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "clean": "rm -rf dist cdk.out node_modules",
    "security:cfn-nag": "cfn_nag_scan --input-path cdk.out --template-pattern=\".*\\.template\\.json$\"",
    "security:scan": "pnpm synth && pnpm security:cfn-nag",
    "validate": "pnpm lint:check && pnpm format:check && pnpm type-check && pnpm test && pnpm security:scan"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.240.0-alpha.0",
    "@aws-lambda-powertools/logger": "^2.10.0",
    "@agentic-app/core": "*",
    "@agentic-app/lambda-chat": "*",
    "@agentic-app/types": "*",
    "aws-cdk-lib": "^2.240.0",
    "constructs": "^10.4.2",
    "dotenv": "^16.4.7",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@agentic-app/config-eslint": "*",
    "@agentic-app/config-ts": "*",
    "@types/aws-lambda": "^8.10.152",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "aws-cdk": "^2.240.0",
    "cdk-nag": "^2.37.55",
    "esbuild": "^0.24.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
