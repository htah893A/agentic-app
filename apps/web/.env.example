# AWS
AWS_REGION=us-east-1

# Cognito (same app client as API authorizer expects)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN_PREFIX=your-domain-prefix

# NextAuth
AUTH_SECRET=your-secret-key-here
AUTH_URL=http://localhost:3000

# API Gateway base URL including stage and trailing slash, e.g.
# https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/v1/api/
API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/v1/api/
