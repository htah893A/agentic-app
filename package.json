{
  "name": "Agentic-app",
  "version": "1.0.0",
  "description": "A comprehensive AWS CDK + Next.js monorepo for deploying a Bedrock Agent with Knowledge Base and web interface",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "type-check": "turbo run type-check",
    "quality:check": "pnpm lint:check && pnpm format:check && pnpm type-check",
    "quality:fix": "pnpm lint && pnpm format",
    "cdk:synth": "pnpm --filter @agentic-app/infra cdk synth",
    "cdk:deploy": "pnpm --filter @agentic-app/infra cdk deploy",
    "cdk:destroy": "pnpm --filter @agentic-app/infra cdk destroy",
    "cdk:diff": "pnpm --filter @agentic-app/infra cdk diff",
    "web:dev": "pnpm --filter @agentic-app/web dev",
    "web:build": "pnpm --filter @agentic-app/web build",
    "deploy": "./scripts/deploy.sh",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24.8.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "aws",
    "bedrock",
    "ai",
    "chatbot",
    "knowledge-base",
    "cdk",
    "nextjs",
    "monorepo",
    "turborepo",
    "template"
  ],
  "author": "Your Name",
  "license": "MIT"
}
